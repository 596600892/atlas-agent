# ──────────────────────────────────────────────
# Atlas Agent — 环境配置模板
# 复制本文件为 .env 并填入你的 API Keys
# ──────────────────────────────────────────────

# === 语音引擎 ===
# Google Speech Recognition (免费, 默认)
# 无需 API Key，直接可用

# === TTS ===
# macOS 内置 say 命令 (默认, 离线可用)
# 或设置自定义 TTS 引擎路径

# === 记忆引擎 (可选) ===
# sentence-transformers 用于语义搜索
# pip install sentence-transformers

# === 路由引擎 ===
# 内置关键词路由, 无需 API Key

# === 日志级别 ===
ATLAS_LOG_LEVEL=WARNING

# === 数据目录 (默认 ~/.atlas) ===
# ATLAS_DATA_DIR=~/.atlas

# === WebUI 配置 (可选) ===
ATLAS_WEB_HOST=0.0.0.0
ATLAS_WEB_PORT=8640
